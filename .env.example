L9_ENVIRONMENT=prod
L9_RUNTIME_MODE=single-node
L9_NODE_NAME=service-template
L9_SERVICE_NAME=service-template
L9_SERVICE_VERSION=1.0.0
L9_DEV_MODE=false
L9_RETURN_PACKET_ERRORS=false
L9_REQUIRE_SIGNATURE=true
L9_EXPOSE_INTERNAL_ERRORS=false
L9_ENABLE_METRICS=false
L9_SIGNING_ALGORITHM=ed25519
L9_SIGNING_PRIVATE_KEY=
L9_SIGNING_KEY_ID=
L9_VERIFYING_KEYS_JSON={}
L9_ALLOWED_ACTIONS=healthcheck
L9_ALLOWED_PACKET_TYPES=request,command,delegation,replay_request
L9_REQUIRE_IDEMPOTENCY_FOR_ACTIONS=
L9_ALLOWED_CLOCK_SKEW_SECONDS=30
L9_MAX_PACKET_BYTES=262144
L9_MAX_HOP_DEPTH=64
L9_MAX_DELEGATION_DEPTH=8
L9_MAX_ATTACHMENTS=32
L9_MAX_ATTACHMENT_SIZE_BYTES=10485760
L9_ATTACHMENT_ALLOWED_SCHEMES=https,s3,gs
L9_ALLOW_PRIVATE_ATTACHMENT_HOSTS=false
L9_STATE_DB_PATH=/var/lib/l9/l9_state.db
L9_MAX_CONCURRENT_EXECUTIONS=100
L9_REPLAY_ENABLED=true
HOST=0.0.0.0
PORT=8000
APP_MODULE=generated_service.app:app
LOG_LEVEL=info
L9_JSON_LOGS=true
L9_BOOTSTRAP_RUNTIME=true
