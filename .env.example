# L9 Engine — required runtime keys
L9_ENVIRONMENT=development
L9_NODE_NAME=l9-node-local
L9_SERVICE_NAME=l9-engine
L9_SERVICE_VERSION=0.0.0
L9_STATE_DB_PATH=/tmp/l9_state.db
L9_APP_MODULE=engine.main:app
L9_REQUIRE_SIGNATURE=false
L9_SIGNING_PRIVATE_KEY=
L9_SIGNING_ALGORITHM=hmac-sha256
L9_ALLOWED_ACTIONS=execute,describe
L9_JSON_LOGS=true
L9_EXPOSE_INTERNAL_ERRORS=false
L9_MAX_PACKET_BYTES=1048576
L9_MAX_HOP_DEPTH=10
L9_MAX_CONCURRENT_EXECUTIONS=100
L9_REPLAY_ENABLED=true
