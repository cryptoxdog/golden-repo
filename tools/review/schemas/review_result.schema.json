{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ReviewResult",
  "type": "object",
  "required": ["dimension", "verdict", "confidence", "findings", "rationale_summary"],
  "properties": {
    "dimension": {"type": "string"},
    "verdict": {
      "type": "string",
      "enum": ["APPROVE", "WARN", "BLOCK", "ESCALATE"]
    },
    "final_verdict": {
      "type": "string",
      "enum": ["APPROVE", "WARN", "BLOCK", "ESCALATE"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["file", "line", "severity", "rule_id", "finding"],
        "properties": {
          "file": {"type": "string"},
          "line": {"type": "integer"},
          "severity": {"type": "string"},
          "rule_id": {"type": "string"},
          "finding": {"type": "string"},
          "waived": {"type": "boolean"},
          "waiver_reason": {"type": ["string", "null"]}
        }
      }
    },
    "waived_findings": {
      "type": "array",
      "items": {"$ref": "#/properties/findings/items"}
    },
    "rationale_summary": {
      "type": "array",
      "items": {"type": "string"}
    },
    "metrics": {
      "type": "object"
    },
    "repro_steps": {
      "type": "array",
      "items": {"type": "string"}
    },
    "suggested_tests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "file", "purpose", "assertion"],
        "properties": {
          "name": {"type": "string"},
          "file": {"type": "string"},
          "purpose": {"type": "string"},
          "assertion": {"type": "string"}
        }
      }
    }
  }
}
