{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ChangeProposal",
  "type": "object",
  "required": ["id", "type", "changed_files", "changed_lines", "diff", "metadata"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": ["code_change", "spec_change", "config_change", "workflow_change"]
    },
    "changed_files": {
      "type": "array",
      "items": {"type": "string"}
    },
    "changed_lines": {
      "type": "integer",
      "minimum": 0
    },
    "diff": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "required": ["base_ref", "head_ref", "source"],
      "properties": {
        "base_ref": {"type": "string"},
        "head_ref": {"type": "string"},
        "source": {"type": "string"},
        "spec_changed": {"type": "boolean"},
        "workflow_changed": {"type": "boolean"},
        "policy_changed": {"type": "boolean"},
        "protected_path_hits": {
          "type": "array",
          "items": {"type": "string"}
        },
        "generated_at": {"type": "string"}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
